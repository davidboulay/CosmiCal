{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CosmiCal",
  "version": "0.2.3",
  "identifier": "org.ren.rencal",
  "mainBinaryName": "rencal",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CosmiCal",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "providers/caldir-provider-google",
      "providers/caldir-provider-icloud",
      "providers/caldir-provider-outlook",
      "providers/caldir-provider-caldav",
      "providers/caldir-provider-webcal",
      "icons/128x128.png"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libnotify-bin"],
        "conflicts": ["ren-cal"],
        "replaces": ["ren-cal"],
        "files": {
          "/usr/bin/rencal-notifierd": "target/release/rencal-notifierd",
          "/usr/lib/systemd/user/rencal-notifierd.service": "notifierd/rencal-notifierd.service"
        }
      },
      "rpm": {
        "depends": ["libnotify"],
        "conflicts": ["ren-cal"],
        "files": {
          "/usr/bin/rencal-notifierd": "target/release/rencal-notifierd",
          "/usr/lib/systemd/user/rencal-notifierd.service": "notifierd/rencal-notifierd.service"
        }
      }
    }
  }
}
